generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  moderator
  customer
}

enum ProductType {
  single
  combo
}

enum StockStatus {
  IN_STOCK
  LIMITED_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  PRE_ORDER
  COMING_SOON
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  returned
  cancelled
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

enum DeliveryType {
  home
  point
}

enum CouponScope {
  ALL_PRODUCTS
  CATEGORY
  PRODUCT
}

enum InventoryMovementType {
  PURCHASE
  SALE
  CANCEL_RESTORE
  RETURN_RESTORE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  LOSS
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  mobile         String?   @unique
  address        String?
  district       String?
  thana          String?
  role           Role      @default(customer)
  isBanned       Boolean   @default(false)
  sessionVersion Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  banners           Banner[]
  orders            Order[]
  reviews           ProductReview[]
  createdCoupons    Coupon[]           @relation("CouponCreatedBy")
  couponRedemptions CouponRedemption[]
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  mobile       String
  passwordHash String
  otpCode      String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model BannedUser {
  id       String   @id @default(cuid())
  email    String   @unique
  mobile   String
  name     String?
  reason   String
  bannedAt DateTime @default(now())
  bannedBy String?
}

model Banner {
  id                 String  @id @default(cuid())
  imageUrl           String
  cloudinaryPublicId String
  productLink        String?
  isPublished        Boolean @default(true)

  createdById    String?
  createdByName  String?
  createdByEmail String?
  createdByRole  Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isPublished])
  @@index([createdByRole])
  @@index([createdAt])
}

model ProductCategory {
  id   String @id @default(cuid())
  name String
  slug String @unique

  description             String?
  imageUrl                String?
  imageCloudinaryPublicId String?
  iconSvg                 String?
  sortOrder               Int     @default(0)
  isPublished             Boolean @default(true)

  subCategories ProductSubCategory[]
  products      Product[]
  coupons       Coupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([sortOrder])
}

model ProductSubCategory {
  id         String          @id @default(cuid())
  name       String
  slug       String
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  description             String?
  imageUrl                String?
  imageCloudinaryPublicId String?
  iconSvg                 String?
  sortOrder               Int     @default(0)
  isPublished             Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([slug])
  @@index([isPublished])
  @@index([sortOrder])
}

model Brand {
  id   String @id @default(cuid())
  name String
  slug String @unique

  logoUrl          String?
  logoCloudinaryId String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Product {
  id   String @id @default(cuid())
  name String
  slug String @unique

  productType ProductType @default(single)

  sku     String? @unique
  barcode String? @unique

  modelName String?

  shortDescription String?
  description      String

  keyFeatures String[] @default([])
  highlights  String[] @default([])

  specifications Json?

  tags           String[] @default([])
  searchKeywords String[] @default([])

  mrp Decimal @db.Decimal(12, 2)

  costPrice    Decimal? @db.Decimal(12, 2)
  sellingPrice Decimal  @db.Decimal(12, 2)

  stock                 Int         @default(0)
  stockStatus           StockStatus @default(IN_STOCK)
  lowStockAlertQuantity Int         @default(5)

  inStock     Boolean @default(true)
  isPublished Boolean @default(true)

  isFeatured    Boolean @default(false)
  isBestSeller  Boolean @default(false)
  isTrending    Boolean @default(false)
  isRecommended Boolean @default(false)
  isFlashSale   Boolean @default(false)

  mainImageUrl      String
  mainImagePublicId String
  mainImageAlt      String?

  hoverImageUrl      String?
  hoverImagePublicId String?
  hoverImageAlt      String?

  videoUrl      String?
  videoPublicId String?

  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  subCategoryId String?
  subCategory   ProductSubCategory? @relation(fields: [subCategoryId], references: [id])

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  extraImages ProductImage[]
  sizeChart   SizeChart?

  warrantyDuration String?
  warrantyDetails  String?

  returnPolicy      String?
  replacementPolicy String?
  refundPolicy      String?

  deliveryInfo   String?
  deliveryTime   String?
  cashOnDelivery Boolean @default(true)
  freeDelivery   Boolean @default(false)

  packageIncludes   String[] @default([])
  packageWeight     String?
  packageDimensions String?

  reviews ProductReview[]

  averageRating Decimal @default(0) @db.Decimal(3, 2)
  totalReviews  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  coupons    Coupon[]

  inventoryBatches   InventoryBatch[]
  inventoryMovements InventoryMovement[]
  averageCost        Decimal             @default(0) @db.Decimal(12, 2)
  lastPurchaseCost   Decimal?            @db.Decimal(12, 2)
  stockValue         Decimal             @default(0) @db.Decimal(12, 2)

  @@index([productType])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([brandId])
  @@index([sellingPrice])
  @@index([stockStatus])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([slug])
  @@index([sku])
}

model Order {
  id        String @id @default(cuid())
  invoiceNo String @unique

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  customerName     String
  customerEmail    String?
  customerPhone    String
  alternativePhone String?
  recipientEmail   String?
  customerAddress  String
  district         String
  thana            String?

  deliveryType DeliveryType @default(home)

  totalAmount    Decimal @db.Decimal(12, 2)
  deliveryCharge Decimal @default(0) @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)

  couponId                 String?
  coupon                   Coupon?      @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode               String?
  couponDiscountScope      CouponScope?
  couponDiscountPercentage Decimal?     @db.Decimal(5, 2)
  couponDiscountAmount     Decimal      @default(0) @db.Decimal(12, 2)

  paidAmount Decimal @default(0) @db.Decimal(12, 2)
  dueAmount  Decimal @default(0) @db.Decimal(12, 2)
  codAmount  Decimal @default(0) @db.Decimal(12, 2)

  note            String?
  itemDescription String?

  status        OrderStatus   @default(pending)
  paymentStatus PaymentStatus @default(unpaid)

  courierName           String?
  courierTrackingNumber String?
  courierNote           String?
  courierAssignedAt     DateTime?

  shippedAt   DateTime?
  deliveredAt DateTime?
  returnedAt  DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items            OrderItem[]
  couponRedemption CouponRedemption?

  productCostTotal    Decimal   @default(0) @db.Decimal(12, 2)
  grossProfit         Decimal   @default(0) @db.Decimal(12, 2)
  actualCourierCost   Decimal   @default(0) @db.Decimal(12, 2)
  packagingCost       Decimal   @default(20) @db.Decimal(12, 2)
  paymentFee          Decimal   @default(0) @db.Decimal(12, 2)
  otherCost           Decimal   @default(0) @db.Decimal(12, 2)
  netProfit           Decimal   @default(0) @db.Decimal(12, 2)
  inventoryRestoredAt DateTime?

  @@index([invoiceNo])
  @@index([userId])
  @@index([status])
  @@index([customerPhone])
  @@index([couponId])
  @@index([couponCode])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productName  String
  productSlug  String?
  productImage String?
  sku          String?

  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  originalUnitPrice   Decimal @default(0) @db.Decimal(12, 2)
  unitDiscountAmount  Decimal @default(0) @db.Decimal(12, 2)
  discountedUnitPrice Decimal @default(0) @db.Decimal(12, 2)
  lineDiscountAmount  Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  unitCostPrice Decimal @default(0) @db.Decimal(12, 2)
  totalCost     Decimal @default(0) @db.Decimal(12, 2)
  profit        Decimal @default(0) @db.Decimal(12, 2)
  costBreakdown Json?

  @@index([orderId])
  @@index([productId])
}

model ProductReview {
  id          String   @id @default(cuid())
  productId   String
  userId      String?
  userName    String?
  userEmail   String
  rating      Int
  comment     String   @db.Text
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  images  ProductReviewImage[]

  @@unique([productId, userEmail])
  @@index([productId])
  @@index([userEmail])
  @@index([createdAt])
}

model ProductReviewImage {
  id                 String        @id @default(cuid())
  reviewId           String
  review             ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  imageUrl           String
  cloudinaryPublicId String
  altText            String?
  sortOrder          Int           @default(0)
  createdAt          DateTime      @default(now())

  @@index([reviewId])
  @@index([sortOrder])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  imageUrl           String
  cloudinaryPublicId String
  altText            String?
  sortOrder          Int     @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([sortOrder])
}

model SizeChart {
  id String @id @default(cuid())

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name        String
  title       String?
  description String?

  unit String @default("inch")

  chartData Json

  imageUrl           String?
  cloudinaryPublicId String?

  note      String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([isActive])
  @@index([sortOrder])
}

model InventoryBatch {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  batchNo String @unique

  purchaseQuantity  Int
  remainingQuantity Int

  unitCostPrice Decimal  @db.Decimal(12, 2)
  mrp           Decimal? @db.Decimal(12, 2)
  sellingPrice  Decimal? @db.Decimal(12, 2)
  totalCost     Decimal  @db.Decimal(12, 2)

  purchaseDate DateTime @default(now())
  note         String?

  movements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([batchNo])
  @@index([purchaseDate])
  @@index([remainingQuantity])
}

model InventoryMovement {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  batchId String?
  batch   InventoryBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  type InventoryMovementType

  // Positive quantity means stock in. Negative quantity means stock out.
  quantity Int

  unitCostPrice Decimal? @db.Decimal(12, 2)
  totalCost     Decimal? @db.Decimal(12, 2)

  reason        String?
  referenceType String?
  referenceNo   String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([batchId])
  @@index([type])
  @@index([referenceNo])
  @@index([createdAt])
}

model Coupon {
  id String @id @default(cuid())

  code        String  @unique
  title       String?
  description String?

  scope              CouponScope @default(ALL_PRODUCTS)
  discountPercentage Decimal     @db.Decimal(5, 2)
  maxDiscountAmount  Decimal?    @db.Decimal(12, 2)
  minOrderAmount     Decimal     @default(0) @db.Decimal(12, 2)

  usageLimit Int?
  usedCount  Int  @default(0)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  startsAt DateTime?
  endsAt   DateTime?
  isActive Boolean   @default(true)

  createdById    String?
  createdBy      User?   @relation("CouponCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName  String?
  createdByEmail String?

  orders      Order[]
  redemptions CouponRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([scope])
  @@index([categoryId])
  @@index([productId])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdAt])
}

model CouponRedemption {
  id String @id @default(cuid())

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  couponCode         String
  discountPercentage Decimal @db.Decimal(5, 2)
  discountAmount     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([couponCode])
  @@index([createdAt])
}

model StoreSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
