generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  moderator
  customer
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  mobile        String?   @unique
  role          Role      @default(customer)
  isBanned      Boolean   @default(false)
  sessionVersion Int      @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  mobile       String
  passwordHash String
  otpCode      String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model BannedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  mobile    String
  name      String?
  reason    String
  bannedAt  DateTime @default(now())
  bannedBy  String?  // admin/moderator id who performed the ban
}